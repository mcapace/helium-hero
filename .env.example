ANTHROPIC_API_KEY=your_anthropic_key_here
# Optional: defaults to Claude Haiku 4.5 (fast). Override e.g. claude-sonnet-4-20250514
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
# Optional: defaults to eleven_flash_v2_5 (low-latency streaming TTS). Keys need text_to_speech enabled.
# ELEVENLABS_MODEL=eleven_flash_v2_5
# Raw email:password — Basic auth is built in app/api/d-id/route.ts (do not pre-base64 here).
D_ID_API_KEY=your_email@example.com:your_password_here
NEXT_PUBLIC_HERO_IMAGE_URL=https://your-domain.vercel.app/images/helium-hero.png
